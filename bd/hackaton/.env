# Environment
ASPNETCORE_ENVIRONMENT=Production
ASPNETCORE_URLS=http://+:80

# ConnectionOptions
ConnectionOptions__DatabaseConnectionTemplate=Host=postgres;Port=5432;Database=hackaton;Username=postgres;Password={0}
ConnectionOptions__RedisConnectionTemplate=redis:6379,password={0},defaultDatabase=0,abortConnect=false,ssl=false
ConnectionOptions__RedisInstanceName=Hackaton:

# JWT Settings
JWT__ISSUER=hack-api
JWT__AUDIENCE=hack-clients
JWT__ACCESS_TOKEN_EXPIRATION_MINUTES=15
JWT__RESET_PASSWORD_TOKEN_EXPIRATION_MINUTES=15
JWT__REFRESH_TOKEN_EXPIRATION_DAYS=1
JWT__ACCESS_COOKIE_NAME=access
JWT__REFRESH_COOKIE_NAME=refresh
JWT__EMAIL_COOKIE_NAME=email
JWT__RESET_PASSWORD_COOKIE_NAME=reset
JWT__USER_ID_COOKIE_NAME=userId
JWT__SESSION_COOKIE_NAME=sessionId

# Logging
LOGGING__LOGLEVEL__DEFAULT=Information
LOGGING__LOGLEVEL__MICROSOFT_ASPNETCORE=Warning
LOGGINGOPTIONS__LOGLEVEL=Information
LOGGINGOPTIONS__CONSOLEENABLED=true
LOGGINGOPTIONS__FILEENABLED=true
LOGGINGOPTIONS__LOGPATH=Logs/app-.log

# Swagger
SWAGGERENABLED=true

# Transaction Options
TRANSACTIONOPTIONS__MAXRETRYCOUNT=3
TRANSACTIONOPTIONS__ENABLERETRYONFAILURE=true
TRANSACTIONOPTIONS__USEEXPONENTIALBACKOFF=true
TRANSACTIONOPTIONS__FIXEDDELAYMS=200

# API Key Options
APIKEYOPTIONS__HEADER=X-Api-Key
APIKEYOPTIONS__USEAPIKEYACCESS=true

# SMTP Options
SMTPOPTIONS__HOST=mail.netangels.ru
SMTPOPTIONS__NAME=Шкеты
SMTPOPTIONS__PORT=587
SMTPOPTIONS__MAXRETRYATTEMPTS=3
SMTPOPTIONS__USEPORTANDSSL=false
SMTPOPTIONS__TIMEOUTSECONDS=30
SMTPOPTIONS__RETRYDELAYSECONDS=5

# Email Template Options
EMAILTEMPLATEOPTIONS__RESOURCESPATH=/app/Resources
EMAILTEMPLATEOPTIONS__EMAILTEMPLATEWITHCODEFILENAME=EmailTemplateWithCode.html

# Verification Options
VERIFICATIONOPTIONS__EMAILTOKENEXPIRATIONMINUTES=5
VERIFICATIONOPTIONS__EMAILTOKENLENGTH=4
VERIFICATIONOPTIONS__PASSWORDTOKENEXPIRATIONMINUTES=5
VERIFICATIONOPTIONS__PASSWORDTOKENLENGTH=4

# CORS
ALLOWEDORIGINS=https://shkets.ru,http://localhost:5173,http://localhost:5000