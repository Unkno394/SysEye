{
  "LoggingOptions": {
    "LogLevel": "Information",
    "ConsoleEnabled": true,
    "FileEnabled": true,
    "LogPath": "Logs/app-.log"
  },
  "JwtOptions": {
    "AccessCookieName": "access",
    "RefreshCookieName": "refresh",
    "ResetPasswordCookieName": "reset",
    "UserIdCookieName": "userId",
    "SessionCookieName": "sessionId",
    "Issuer": "hack-api",
    "Audience": "hack-clients",
    "AccessTokenExpirationMinutes": 15,
    "RefreshTokenExpirationDays": 1
  },
  "SwaggerEnabled": true,
  "ConnectionOptions": {
    "DatabaseConnectionTemplate": "Host=localhost;Port=5432;Database=hackaton;Username=postgres;Password={0}",
    "RedisConnectionTemplate": "redis:6379,password={0},defaultDatabase=0,abortConnect=false,ssl=false",
    "RedisInstanceName": "Hackaton:"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "TransactionOptions": {
    "MaxRetryCount": 3,
    "EnableRetryOnFailure": true,
    "UseExponentialBackoff": true,
    "FixedDelayMs": 200
  },
  "ApiKeyOptions": {
    "ApiKeyHeader": "X-Api-Key",
    "AgentIdHeader": "X-Agent-Id",
    "UseApiKeyAccess": true
  },
  "SmtpOptions": {
    "Host": "mail.netangels.ru",
    "Name": "Шкеты",
    "Port": 587,
    "MaxRetryAttempts": 3,
    "UsePortAndSsl": false,
    "TimeoutSeconds": 30,
    "RetryDelaySeconds": 5
  },
  "EmailTemplateOptions": {
    "ResourcesPath": "../Resources",
    "EmailTemplateWithCodeFileName": "EmailTemplateWithCode.html"
  },
  "VerificationOptions": {
    "EmailTokenExpirationMinutes": 5,
    "EmailTokenLength": 4,
    "PasswordTokenExpirationMinutes": 5,
    "PasswordTokenLength": 4
  },

  "AllowedOrigins": "https://shkets.ru,http://localhost:3001,http://localhost:5173,http://localhost:5000,http://192.168.31.223:5273,http://192.168.31.159:7225"
}
